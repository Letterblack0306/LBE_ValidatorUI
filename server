import http from 'node:http';
import fs from 'node:fs/promises';
import fssync from 'node:fs';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const PORT = Number(process.env.PORT || 7766);
const HOST = process.env.HOST || '127.0.0.1';
const PUBLIC_DIR = path.join(__dirname, 'public');
const CONFIG_PATH = path.join(__dirname, 'config', 'projects.json');

const MIME = {
  '.html': 'text/html; charset=utf-8',
  '.css': 'text/css; charset=utf-8',
  '.js': 'application/javascript; charset=utf-8',
  '.json': 'application/json; charset=utf-8',
  '.txt': 'text/plain; charset=utf-8',
  '.svg': 'image/svg+xml; charset=utf-8'
};

function json(res, statusCode, data) {
  const body = JSON.stringify(data, null, 2);
  res.writeHead(statusCode, {
    'content-type': 'application/json; charset=utf-8',
    'cache-control': 'no-store'
  });
  res.end(body);
}

function text(res, statusCode, body) {
  res.writeHead(statusCode, {
    'content-type': 'text/plain; charset=utf-8',
    'cache-control': 'no-store'
  });
  res.end(body);
}

function isSubPath(child, parent) {
  const rel = path.relative(parent, child);
  return rel === '' || (!rel.startsWith('..') && !path.isAbsolute(rel));
}

function toPosixPath(value) {
  return String(value || '').replace(/\\/g, '/');
}

function normalizeLocalPath(value, baseDir = __dirname) {
  if (!value) return null;
  const raw = String(value).trim().replace(/^file:\/\//i, '');
  const normalizedSeparators = raw.replace(/\\/g, '/');

  // Windows absolute path support, even when running from ESM on Windows.
  if (/^[a-zA-Z]:\//.test(normalizedSeparators)) {
    return path.normalize(normalizedSeparators);
  }

  // UNC path support.
  if (normalizedSeparators.startsWith('//')) {
    return path.normalize(normalizedSeparators);
  }

  return path.isAbsolute(normalizedSeparators)
    ? path.normalize(normalizedSeparators)
    : path.resolve(baseDir, normalizedSeparators);
}

async function readJson(filePath) {
  const raw = await fs.readFile(filePath, 'utf8');
  return JSON.parse(raw);
}

async function writeJson(filePath, data) {
  await fs.mkdir(path.dirname(filePath), { recursive: true });
  await fs.writeFile(filePath, `${JSON.stringify(data, null, 2)}\n`, 'utf8');
}

async function exists(filePath) {
  if (!filePath) return false;
  try {
    await fs.stat(filePath);
    return true;
  } catch {
    return false;
  }
}

async function isDirectory(filePath) {
  try {
    return (await fs.stat(filePath)).isDirectory();
  } catch {
    return false;
  }
}

async function isFile(filePath) {
  try {
    return (await fs.stat(filePath)).isFile();
  } catch {
    return false;
  }
}

function makeProjectId(name, existingProjects = []) {
  const base = String(name || '')
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '') || `project-${Date.now()}`;

  const used = new Set(existingProjects.map((p) => p.id));
  if (!used.has(base)) return base;

  let i = 2;
  while (used.has(`${base}-${i}`)) i += 1;
  return `${base}-${i}`;
}

function loadableProjectFromConfigEntry(p, index) {
  const root = normalizeLocalPath(p.root, __dirname);
  const truth = p.truth ? normalizeLocalPath(p.truth, __dirname) : null;
  return {
    id: p.id || `project-${index + 1}`,
    name: p.name || p.id || `Project ${index + 1}`,
    root,
    truth,
    raw: p
  };
}

async function readConfig() {
  try {
    const config = await readJson(CONFIG_PATH);
    return { projects: Array.isArray(config.projects) ? config.projects : [] };
  } catch {
    return { projects: [] };
  }
}

async function loadConfig() {
  const config = await readConfig();
  return config.projects.map(loadableProjectFromConfigEntry);
}

async function readLatestPointer(pointerPath, root, checkedPaths) {
  checkedPaths.push(pointerPath);
  if (!(await exists(pointerPath))) return null;

  const pointer = await readJson(pointerPath);
  if (pointer.summary) {
    const candidate = normalizeLocalPath(pointer.summary, root);
    checkedPaths.push(candidate);
    if (await exists(candidate)) return candidate;
  }

  if (pointer.runId) {
    const candidate = path.join(root, '.truth', 'runs', pointer.runId, 'summary.json');
    checkedPaths.push(candidate);
    if (await exists(candidate)) return candidate;
  }

  return null;
}

async function findNewestRunSummary(runsDir, checkedPaths) {
  checkedPaths.push(path.join(runsDir, '*', 'summary.json'));
  if (!(await isDirectory(runsDir))) return null;

  const entries = await fs.readdir(runsDir, { withFileTypes: true });
  const dirs = [];
  for (const entry of entries) {
    if (!entry.isDirectory() || entry.name === 'latest') continue;
    const dirPath = path.join(runsDir, entry.name);
    let mtimeMs = 0;
    try { mtimeMs = (await fs.stat(dirPath)).mtimeMs; } catch {}
    dirs.push({ name: entry.name, mtimeMs });
  }

  dirs.sort((a, b) => {
    if (b.name !== a.name) return b.name.localeCompare(a.name);
    return b.mtimeMs - a.mtimeMs;
  });

  for (const dir of dirs) {
    const candidate = path.join(runsDir, dir.name, 'summary.json');
    checkedPaths.push(candidate);
    if (await exists(candidate)) return candidate;
  }

  return null;
}

async function resolveSummaryFromPath(inputPath) {
  const checkedPaths = [];
  const initial = normalizeLocalPath(inputPath, __dirname);

  if (!initial) {
    const err = new Error('Path is required.');
    err.statusCode = 400;
    err.checkedPaths = checkedPaths;
    throw err;
  }

  checkedPaths.push(initial);

  if (initial.toLowerCase().endsWith('summary.json')) {
    if (await exists(initial)) {
      return {
        summaryPath: initial,
        root: deriveProjectRootFromSummary(initial),
        checkedPaths
      };
    }
    const err = new Error('summary.json file not found.');
    err.statusCode = 400;
    err.checkedPaths = checkedPaths;
    throw err;
  }

  if (initial.toLowerCase().endsWith('latest-run.json')) {
    if (await exists(initial)) {
      const root = deriveProjectRootFromLatestPointer(initial);
      const summaryPath = await readLatestPointer(initial, root, checkedPaths);
      if (summaryPath) return { summaryPath, root, checkedPaths };
    }
    const err = new Error('latest-run.json did not resolve to a summary.json.');
    err.statusCode = 400;
    err.checkedPaths = checkedPaths;
    throw err;
  }

  const root = await isDirectory(initial) ? initial : path.dirname(initial);
  const baseName = path.basename(root).toLowerCase();
  const isTruthDir = baseName === '.truth';
  const projectRoot = isTruthDir ? path.dirname(root) : root;
  const truthRoot = isTruthDir ? root : path.join(projectRoot, '.truth');

  const pointerSummary = await readLatestPointer(path.join(truthRoot, 'latest-run.json'), projectRoot, checkedPaths);
  if (pointerSummary) return { summaryPath: pointerSummary, root: projectRoot, checkedPaths };

  const latestSummary = path.join(truthRoot, 'runs', 'latest', 'summary.json');
  checkedPaths.push(latestSummary);
  if (await exists(latestSummary)) return { summaryPath: latestSummary, root: projectRoot, checkedPaths };

  const newest = await findNewestRunSummary(path.join(truthRoot, 'runs'), checkedPaths);
  if (newest) return { summaryPath: newest, root: projectRoot, checkedPaths };

  const directRunsLatest = path.join(root, 'runs', 'latest', 'summary.json');
  checkedPaths.push(directRunsLatest);
  if (await exists(directRunsLatest)) return { summaryPath: directRunsLatest, root: projectRoot, checkedPaths };

  const err = new Error('No summary.json found. Run tools/proof-session.mjs first, then load the project root or summary.json.');
  err.statusCode = 400;
  err.checkedPaths = checkedPaths;
  throw err;
}

function deriveProjectRootFromSummary(summaryPath) {
  const parts = path.normalize(summaryPath).split(path.sep);
  const truthIndex = parts.lastIndexOf('.truth');
  if (truthIndex > 0) return parts.slice(0, truthIndex).join(path.sep) || path.parse(summaryPath).root;
  return path.dirname(summaryPath);
}

function deriveProjectRootFromLatestPointer(pointerPath) {
  const dir = path.dirname(pointerPath);
  return path.basename(dir).toLowerCase() === '.truth' ? path.dirname(dir) : dir;
}

async function resolveTruthSummary(project) {
  const checkedPaths = [];

  if (project.truth) {
    checkedPaths.push(project.truth);
    if (await exists(project.truth)) return project.truth;
  }

  try {
    const result = await resolveSummaryFromPath(project.root);
    return result.summaryPath;
  } catch (err) {
    const message = `No summary.json found for ${project.name}.`;
    const out = new Error(message);
    out.statusCode = err.statusCode || 400;
    out.checkedPaths = [...checkedPaths, ...(err.checkedPaths || [])];
    throw out;
  }
}

function statusRank(status) {
  const s = String(status || '').toUpperCase();
  if (['FAIL', 'FAILED', 'BLOCKED', 'ERROR'].includes(s)) return 0;
  if (['WARN', 'WARNING', 'UNKNOWN'].includes(s)) return 1;
  if (['PENDING', 'SKIPPED'].includes(s)) return 2;
  if (['PASS', 'READY', 'OK', 'SUCCESS'].includes(s)) return 3;
  return 2;
}

function normalizeStatus(status) {
  const s = String(status || 'UNKNOWN').toUpperCase();
  if (['READY', 'OK', 'SUCCESS'].includes(s)) return 'PASS';
  if (['BLOCKED', 'FAILED', 'ERROR'].includes(s)) return 'FAIL';
  if (['WARNING'].includes(s)) return 'WARN';
  return s;
}

function evidenceToDisplay(value) {
  if (!value) return null;
  if (typeof value === 'string') return value;
  if (Array.isArray(value)) return value.flatMap((item) => evidenceToDisplay(item)).filter(Boolean);
  if (typeof value === 'object') {
    const out = [];
    if (value.stdoutFile) out.push(value.stdoutFile);
    if (value.stderrFile) out.push(value.stderrFile);
    if (value.file) out.push(value.file);
    if (value.path) out.push(value.path);
    if (value.summary) out.push(value.summary);
    if (!out.length && value.commandId) out.push(`commands.jsonl#${value.commandId}`);
    return out.length ? out : JSON.stringify(value);
  }
  return String(value);
}

function normalizeGraph(summary) {
  const modules = Array.isArray(summary.modules) ? summary.modules : [];
  const checks = Array.isArray(summary.checks) ? summary.checks : [];
  const source = modules.length > 0 ? modules : checks.map((check) => ({
    moduleId: check.moduleId || check.id,
    label: check.label || check.name || check.id,
    type: check.type || 'check',
    parent: check.parent || null,
    targetAction: check.targetAction || null,
    connectedTo: check.connectedTo || {},
    status: check.status,
    evidence: check.evidence,
    rawCheck: check
  }));

  const nodes = source.map((item, index) => {
    const id = item.moduleId || item.id || item.name || `node-${index + 1}`;
    return {
      id,
      label: item.label || item.name || id,
      type: item.type || 'module',
      parent: item.parent || null,
      targetAction: item.targetAction || null,
      connectedTo: item.connectedTo || {},
      status: normalizeStatus(item.status),
      evidence: evidenceToDisplay(item.evidence),
      raw: item
    };
  });

  const ids = new Set(nodes.map((node) => node.id));
  const edges = [];
  const synthetic = [];

  function addSynthetic(id, label, type, raw) {
    if (ids.has(id)) return;
    ids.add(id);
    synthetic.push({
      id,
      label,
      type,
      parent: null,
      targetAction: null,
      connectedTo: {},
      status: 'FAIL',
      evidence: null,
      raw
    });
  }

  for (const node of nodes) {
    const c = node.connectedTo || {};

    if (c.left) {
      if (ids.has(c.left)) edges.push({ from: c.left, to: node.id, type: 'left', status: node.status });
      else {
        const missingId = `missing-left:${c.left}`;
        addSynthetic(missingId, `Missing left: ${c.left}`, 'missing_left', {
          reason: 'Declared connectedTo.left does not exist as a node in the proof summary.',
          declaredLeft: c.left,
          owner: node.id
        });
        edges.push({ from: missingId, to: node.id, type: 'missing-left', status: 'FAIL' });
      }
    }

    if (c.right) {
      if (ids.has(c.right)) edges.push({ from: node.id, to: c.right, type: 'right', status: node.status });
      else {
        const missingId = `missing-right:${c.right}`;
        addSynthetic(missingId, `Missing right: ${c.right}`, 'missing_right', {
          reason: 'Declared connectedTo.right does not exist as a node in the proof summary.',
          declaredRight: c.right,
          owner: node.id
        });
        edges.push({ from: node.id, to: missingId, type: 'missing-right', status: 'FAIL' });
      }
    }

    if (node.parent) {
      if (ids.has(node.parent)) edges.push({ from: node.parent, to: node.id, type: 'parent', status: node.status });
      else {
        const parentId = `missing-parent:${node.parent}`;
        addSynthetic(parentId, `Missing parent: ${node.parent}`, 'missing_parent', {
          reason: 'Declared parent does not exist as a node in the proof summary.',
          declaredParent: node.parent,
          owner: node.id
        });
        edges.push({ from: parentId, to: node.id, type: 'missing-parent', status: 'FAIL' });
      }
    }

    if (!node.targetAction) {
      const targetId = `missing-target:${node.id}`;
      addSynthetic(targetId, `Missing target action: ${node.id}`, 'missing_target', {
        reason: 'Node has no targetAction declared.',
        owner: node.id
      });
      edges.push({ from: node.id, to: targetId, type: 'missing-target', status: 'FAIL' });
    }
  }

  return { nodes: [...synthetic, ...nodes], edges };
}

async function readOptionalRunFiles(runDir) {
  const candidates = [
    'manifest.json',
    'summary.json',
    'commands.jsonl',
    'files.jsonl',
    'hashes.jsonl',
    'final-receipt.txt',
    'release-public-tree.txt',
    'public-clone-tree.txt',
    'public-compare.json',
    'forbidden-findings.json'
  ];

  const result = {};
  for (const file of candidates) {
    const filePath = path.join(runDir, file);
    if (await exists(filePath)) {
      const stat = await fs.stat(filePath);
      const maxBytes = 256 * 1024;
      let content = await fs.readFile(filePath, 'utf8');
      if (Buffer.byteLength(content, 'utf8') > maxBytes) {
        content = `${content.slice(0, maxBytes)}\n\n[TRUNCATED BY TRUTH CONSOLE VIEWER]`;
      }
      result[file] = { path: filePath, size: stat.size, content };
    }
  }
  return result;
}

async function getProjectBundle(projectId, customPath = null) {
  let project;
  let summaryPath;
  let checkedPaths = [];

  if (customPath) {
    const resolved = await resolveSummaryFromPath(customPath);
    summaryPath = resolved.summaryPath;
    checkedPaths = resolved.checkedPaths;
    project = {
      id: 'custom',
      name: path.basename(resolved.root) || resolved.root,
      root: resolved.root,
      truth: summaryPath
    };
  } else {
    const projects = await loadConfig();
    project = projects.find((p) => p.id === projectId) || (projects.length > 0 ? projects[0] : null);
    if (!project) {
      const err = new Error('No project found or specified. Configure projects in config/projects.json or load a custom path.');
      err.statusCode = 400;
      throw err;
    }
    summaryPath = await resolveTruthSummary(project);
  }

  const summary = await readJson(summaryPath);
  const runDir = path.dirname(summaryPath);
  const runFiles = await readOptionalRunFiles(runDir);
  const graph = normalizeGraph(summary);

  const checkCounts = graph.nodes.reduce((acc, node) => {
    const key = normalizeStatus(node.status);
    acc[key] = (acc[key] || 0) + 1;
    return acc;
  }, {});

  return {
    project: {
      id: project.id,
      name: project.name,
      root: project.root,
      truth: summaryPath
    },
    summary,
    graph,
    runFiles,
    meta: {
      runDir,
      loadedAt: new Date().toISOString(),
      checkCounts,
      worstRank: graph.nodes.length ? Math.min(...graph.nodes.map((node) => statusRank(node.status))) : null,
      checkedPaths
    }
  };
}

async function listProjectsForApi() {
  const projects = await loadConfig();
  return Promise.all(projects.map(async (p) => {
    let status = 'UNKNOWN';
    let runId = null;
    let truth = p.truth;
    let error = null;
    try {
      truth = await resolveTruthSummary(p);
      const summary = await readJson(truth);
      status = summary.status || 'UNKNOWN';
      runId = summary.runId || null;
    } catch (err) {
      error = err.message;
    }
    return {
      id: p.id,
      name: p.name,
      root: p.root,
      truth,
      status,
      runId,
      error
    };
  }));
}

async function readRequestJson(req) {
  const chunks = [];
  for await (const chunk of req) chunks.push(chunk);
  const raw = Buffer.concat(chunks).toString('utf8').trim();
  return raw ? JSON.parse(raw) : {};
}

async function saveProject(req, res) {
  const body = await readRequestJson(req);
  const name = String(body.name || '').trim();
  const root = normalizeLocalPath(body.root || '', __dirname);

  if (!name) return json(res, 400, { error: 'name is required' });
  if (!root || !(await exists(root))) return json(res, 400, { error: `Folder not found: ${root || body.root || ''}` });

  const config = await readConfig();
  const id = makeProjectId(name, config.projects);
  config.projects.push({ id, name, root: toPosixPath(root) });
  await writeJson(CONFIG_PATH, config);
  return json(res, 200, { ok: true, id, name, root: toPosixPath(root) });
}

async function deleteProject(res, id) {
  if (!id) return json(res, 400, { error: 'id required' });
  const config = await readConfig();
  const before = config.projects;
  const after = before.filter((p) => p.id !== id);
  if (after.length === before.length) return json(res, 404, { error: 'Project not found' });
  await writeJson(CONFIG_PATH, { projects: after });
  return json(res, 200, { ok: true });
}

async function listDirectorySuggestions(rawPath) {
  const suggestions = [];

  if (process.platform === 'win32' && !rawPath) {
    for (let c = 65; c <= 90; c += 1) {
      const drive = `${String.fromCharCode(c)}:/`;
      if (await exists(drive)) suggestions.push(drive);
    }
    return suggestions;
  }

  const normalized = rawPath ? String(rawPath).replace(/\\/g, '/') : '';
  let base;
  let prefix = '';

  if (!normalized) {
    base = process.platform === 'win32' ? process.cwd().slice(0, 3) : '/';
  } else if (await isDirectory(normalizeLocalPath(normalized, process.cwd()))) {
    base = normalizeLocalPath(normalized, process.cwd());
  } else {
    base = normalizeLocalPath(path.dirname(normalized), process.cwd());
    prefix = path.basename(normalized).toLowerCase();
  }

  let entries = [];
  try {
    entries = await fs.readdir(base, { withFileTypes: true });
  } catch {
    return [];
  }

  return entries
    .filter((entry) => entry.isDirectory())
    .filter((entry) => !entry.name.startsWith('$'))
    .filter((entry) => !prefix || entry.name.toLowerCase().startsWith(prefix))
    .slice(0, 60)
    .map((entry) => toPosixPath(path.join(base, entry.name)));
}

async function serveStatic(req, res, pathname) {
  let requestedPath = pathname === '/' ? '/index.html' : pathname;
  requestedPath = decodeURIComponent(requestedPath);
  const filePath = path.normalize(path.join(PUBLIC_DIR, requestedPath));
  if (!isSubPath(filePath, PUBLIC_DIR)) return text(res, 403, 'Forbidden');

  try {
    const body = await fs.readFile(filePath);
    const ext = path.extname(filePath).toLowerCase();
    res.writeHead(200, {
      'content-type': MIME[ext] || 'application/octet-stream',
      'cache-control': 'no-store'
    });
    res.end(body);
  } catch {
    text(res, 404, 'Not found');
  }
}

const server = http.createServer(async (req, res) => {
  try {
    const requestUrl = new URL(req.url || '/', `http://${req.headers.host || `${HOST}:${PORT}`}`);
    const pathname = requestUrl.pathname;
    const method = req.method || 'GET';

    if (pathname === '/api/health' && method === 'GET') {
      return json(res, 200, { ok: true, now: new Date().toISOString(), config: CONFIG_PATH });
    }

    if (pathname === '/api/projects' && method === 'GET') {
      return json(res, 200, { projects: await listProjectsForApi() });
    }

    if (pathname === '/api/projects' && method === 'POST') {
      return await saveProject(req, res);
    }

    if (pathname.startsWith('/api/projects/') && method === 'DELETE') {
      const id = decodeURIComponent(pathname.slice('/api/projects/'.length));
      return await deleteProject(res, id);
    }

    if (pathname === '/api/project' && method === 'GET') {
      const id = requestUrl.searchParams.get('id') || undefined;
      const customPath = requestUrl.searchParams.get('path') || undefined;
      try {
        return json(res, 200, await getProjectBundle(id, customPath));
      } catch (err) {
        return json(res, err.statusCode || 400, {
          error: err.message,
          checkedPaths: err.checkedPaths || []
        });
      }
    }

    if (pathname === '/api/fs/dirs' && method === 'GET') {
      const rawPath = requestUrl.searchParams.get('path') || '';
      return json(res, 200, { dirs: await listDirectorySuggestions(rawPath) });
    }

    if (method !== 'GET' && method !== 'HEAD') {
      return json(res, 405, { error: `Method ${method} not allowed for ${pathname}` });
    }

    return serveStatic(req, res, pathname);
  } catch (err) {
    return json(res, 500, {
      error: err.message,
      stack: process.env.NODE_ENV === 'development' ? err.stack : undefined
    });
  }
});

server.listen(PORT, HOST, () => {
  console.log(`LetterBlack Truth Console running at http://${HOST}:${PORT}`);
  console.log(`Config: ${CONFIG_PATH}`);
});
